datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Review {
  id         String   @id @default(uuid())
  rating     Int
  fullName   String
  location   String
  reviewText String
  photoUrl   String?
  createdAt  DateTime @default(now())
}
